# ======================
# Application Settings
# ======================
APP_NAME=smart-intrusion-detection
APP_ENV=development
DEBUG=true

# ======================
# FastAPI Backend
# ======================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ======================
# MQTT Broker (Mosquitto)
# ======================
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ======================
# Database
# ======================
DATABASE_URL=postgresql://user:password@localhost:5432/intrusion_db

# ======================
# AI / Risk Engine
# ======================
RISK_THRESHOLD_SUSPECT=50
RISK_THRESHOLD_CRITICAL=80
