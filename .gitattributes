# Normalize line endings to LF on commit
* text=auto eol=lf

# Shell scripts: always LF
*.sh text eol=lf

# Python: always LF
*.py text eol=lf

# Config/data files: always LF
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.conf text eol=lf
*.env text eol=lf

# Windows-specific: keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary: no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.key binary
*.pem binary
*.crt binary
*.der binary
